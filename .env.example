# =============================================================================
# THIS FILE IS A TEMPLATE ONLY — Node does NOT load .env.example at runtime.
# Keep your real secrets and URIs in `.env` (same folder as this file). The API
# only loads `.env` via dotenv. Do not replace `.env` with this file.
# `.env` is listed in `.gitignore` so it is not committed.
# =============================================================================

PORT=5000

# --- MongoDB (choose ONE style) ---------------------------------------------

# Local:
# MONGO_URI=mongodb://127.0.0.1:27017/secure-logs
# Windows local data path: npm run mongo:local   then use the URI above.

# Atlas (MongoDB Server) — MUST include database name before ?  e.g. /secure-logs
# MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/secure-logs?retryWrites=true&w=majority&appName=Cluster0
#
# Atlas checklist:
#   - Network Access: allow your IP (or 0.0.0.0/0 for dev only)
#   - Database user: readWrite on that database (or readWriteAnyDatabase)
#   - URI must not be ...mongodb.net/?... without /dbname before ?

JWT_SECRET=replace-with-long-random-string-at-least-16-chars

# First account with this exact username becomes admin (optional).
# BOOTSTRAP_ADMIN_USERNAME=youradminname

# Optional: restrict browser origins (comma-separated). If unset, CORS allows all origins.
CORS_ORIGIN=http://localhost:3000

# --- Blockchain (optional for API; required for on-chain anchoring) ---------
# PRIVATE_KEY must be 64 hex characters (32 bytes), optional 0x prefix.

RPC_URL=
CONTRACT_ADDRESS=
PRIVATE_KEY=
